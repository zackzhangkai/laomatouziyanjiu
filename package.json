{
  "name": "laomatouziyanjiu",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler pages dev dist",
    "db:migrate:local": "wrangler d1 execute blog-db --local --file=./schema.sql",
    "db:migrate": "wrangler d1 execute blog-db --file=./schema.sql",
    "db:migrate:page-views:local": "wrangler d1 execute blog-db --local --file=./migrations/004_page_views.sql",
    "db:migrate:page-views": "wrangler d1 execute blog-db --remote --file=./migrations/004_page_views.sql",
    "db:migrate:twitter-sync:local": "wrangler d1 execute blog-db --local --file=./migrations/005_twitter_sync.sql",
    "db:migrate:twitter-sync": "wrangler d1 execute blog-db --remote --file=./migrations/005_twitter_sync.sql",
    "db:backfill:twitter-imports": "node scripts/backfill-twitter-imports.mjs > migrations/005_twitter_sync_backfill.sql",
    "db:seed:local": "wrangler d1 execute blog-db --local --file=./seed.sql",
